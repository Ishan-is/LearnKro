{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite",
            "buildCommand": "npm run build --prefix frontend",
            "outputDirectory": "dist"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend",
            "framework": "node",
            "buildCommand": "npm install --prefix backend && npm run build --prefix backend"
        }
    }
}